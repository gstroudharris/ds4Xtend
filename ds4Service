#!/usr/bin/env bash
# ds4Service — one-command launcher for the whole DS4 stack:
#   ds4-server (inference, :8080)  +  metrics sidecar (:8081)  +  ds4Frontend web UI (:8090)
#
# What it does:
#   1. On first run (or with --setup), asks for + remembers the ds4 install directory;
#      otherwise reuses the saved one. (--setup is where future options will live.)
#   2. "Installs" / readies the metrics sidecar (it ships next to this script).
#   3. Checks the ports it needs; if a stale ds4 process is holding one, offers to close it (Y/n).
#      Then launches ds4-server (RAM-optimized) and waits until it's online.
#   4. Starts the sidecar + agent-tools (sandboxed file I/O) + the static frontend, then opens
#      the dashboard in your browser (only if a dashboard tab isn't already open).
#   5. Streams ds4 + frontend debug output live.
#   6. On Ctrl+C, stops everything it started, announcing each one.
#
# Ports/context via env: DS4_SERVER_PORT DS4_SIDE_PORT DS4_WEB_PORT DS4_CTX.  Skip warm: DS4_NO_WARM=1.
# Hardware-agnostic: the GPU backend is auto-detected (nvidia-smi->cuda, rocm-smi->rocm, else cpu).
#   Override per box:  --ds4-flags "--rocm --ssd-streaming"   (also DS4_SERVER_FLAGS / DS4_BACKEND /
#   DS4_SERVER_ENV / DS4_LD_PATH, or a sourced ~/.config/ds4service/profile). Env is inherited, e.g.
#   HSA_OVERRIDE_GFX_VERSION=11.0.0 ./ds4Service       (--cors/--port/--ctx are always added by us.)
# Re-run setup (change the dir): --setup
# Browser: opens the dashboard in a window it OWNS (Chrome/Chromium --app, else a separate
# Firefox instance) so Ctrl+C closes just the dashboard, not your other tabs. DS4_NO_BROWSER=1
# disables; DS4_BROWSER="<cmd>" overrides the launch command (the URL is appended).
set -uo pipefail

# ---------- locations ----------
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND_DIR="$SCRIPT_DIR"                       # repo root (holds ds4Service, docs/, code/)
CODE_DIR="$FRONTEND_DIR/code"                    # web assets + sidecar live here
SIDECAR="$CODE_DIR/metrics_sidecar.py"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ds4service"
CONFIG_FILE="$CONFIG_DIR/dir"
RUN_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ds4service.XXXXXX")"

SERVER_PORT="${DS4_SERVER_PORT:-8080}"
SIDE_PORT="${DS4_SIDE_PORT:-8081}"
AGENT_PORT="${DS4_AGENT_PORT:-8082}"
WEB_PORT="${DS4_WEB_PORT:-8090}"
SERVER_CTX="${DS4_CTX:-100000}"

# ---------- pretty output ----------
if [ -t 1 ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; GRN=$'\033[32m'; YEL=$'\033[33m'; RED=$'\033[31m'; CYN=$'\033[36m'; RST=$'\033[0m'
else B=""; DIM=""; GRN=""; YEL=""; RED=""; CYN=""; RST=""; fi
say()  { printf '%s==>%s %s\n' "$B$CYN" "$RST" "$*"; }
ok()   { printf '    %s✓%s %s\n' "$GRN" "$RST" "$*"; }
warn() { printf '    %s!%s %s\n' "$YEL" "$RST" "$*"; }
errln(){ printf '    %s✗%s %s\n' "$RED" "$RST" "$*" >&2; }

# ---------- service registry + teardown ----------
declare -a SVC_NAMES=() SVC_PIDS=()
register() { SVC_NAMES+=("$1"); SVC_PIDS+=("$2"); }
TAIL_PID=""

cleanup() {
  trap '' INT TERM                      # ignore repeat Ctrl+C during shutdown
  [ -n "$TAIL_PID" ] && kill "$TAIL_PID" 2>/dev/null
  printf '\n%sCtrl+C — shutting down ds4Service. Stopping services:%s\n' "$B$YEL" "$RST"
  local i name pid
  for ((i=${#SVC_PIDS[@]}-1; i>=0; i--)); do      # reverse order (frontend → server)
    name="${SVC_NAMES[$i]}"; pid="${SVC_PIDS[$i]}"
    if kill -0 "$pid" 2>/dev/null; then
      printf '  %s•%s stopping %-22s (pid %s)\n' "$CYN" "$RST" "$name" "$pid"
      kill "$pid" 2>/dev/null
    else
      printf '  %s•%s %-22s already stopped\n' "$DIM" "$RST" "$name"
    fi
  done
  sleep 1
  for pid in ${SVC_PIDS[@]+"${SVC_PIDS[@]}"}; do kill -9 "$pid" 2>/dev/null; done  # force stragglers
  wait 2>/dev/null
  rm -rf "$RUN_DIR" 2>/dev/null
  printf '%sAll ds4 services stopped.%s\n' "$GRN" "$RST"
  exit 0
}
trap cleanup INT TERM

# ---------- helpers ----------
wait_http() {  # url timeout_s
  local url="$1" t="$2" i=0
  while [ "$i" -lt "$t" ]; do
    [ "$(curl -s -o /dev/null -w '%{http_code}' "$url" 2>/dev/null)" = "200" ] && return 0
    sleep 1; i=$((i+1)); printf '.'
  done
  return 1
}
port_in_use() { ss -ltn 2>/dev/null | grep -q ":$1 "; }

# If a needed port is busy, show the owner; for our own stale processes, offer to close it (and any others).
preflight_ports() {  # args: "port:label" ...
  local spec port pid cmd found foreign=0 i=0 stillup p d ans=""
  local -a bp_ports=() bp_pids=() bp_desc=()
  for spec in "$@"; do
    port="${spec%%:*}"
    port_in_use "$port" || continue
    found=0
    for pid in $(ss -ltnp 2>/dev/null | grep ":$port " | grep -oE 'pid=[0-9]+' | grep -oE '[0-9]+' | sort -u); do
      found=1
      cmd=$(ps -o args= -p "$pid" 2>/dev/null | tr -s ' ')
      bp_ports+=("$port"); bp_pids+=("$pid"); bp_desc+=(":$port  pid $pid  ${cmd:0:82}")
      case "$cmd" in *ds4-server*|*metrics_sidecar*|*agent_tools*|*http.server*) ;; *) foreign=1 ;; esac
    done
    [ "$found" = 0 ] && { bp_desc+=(":$port  in use (owner hidden — needs sudo to see)"); foreign=1; }
  done
  [ "${#bp_desc[@]}" -eq 0 ] && return 0
  warn "needed port(s) already in use:"
  for d in "${bp_desc[@]}"; do echo "        $d"; done
  if [ "$foreign" = 1 ]; then
    errln "one is an unrelated/hidden process — close it yourself, or change ports (DS4_*_PORT)"; return 1
  fi
  if [ ! -t 0 ]; then errln "re-run ds4Service in an interactive terminal to be offered to close them"; return 1; fi
  read -r -p "    Close ${#bp_pids[@]} running ds4 process(es) and continue? [Y/n]: " ans || ans="n"
  case "${ans:-Y}" in [Nn]*) errln "left them running — cannot continue"; return 1 ;; esac
  for pid in "${bp_pids[@]}"; do kill "$pid" 2>/dev/null; done       # graceful — ds4-server drains on SIGTERM
  while [ "$i" -lt 12 ]; do
    stillup=0; for p in "${bp_ports[@]}"; do port_in_use "$p" && stillup=1; done
    [ "$stillup" = 0 ] && break; sleep 0.5; i=$((i+1))
  done
  if [ "${stillup:-0}" = 1 ]; then warn "still up — forcing"; for pid in "${bp_pids[@]}"; do kill -9 "$pid" 2>/dev/null; done; sleep 0.7; fi
  for p in "${bp_ports[@]}"; do port_in_use "$p" && { errln "could not free port $p"; return 1; }; done
  ok "closed ${#bp_pids[@]} process(es) — ports are free"
}

# Open the dashboard unless one already appears open (an open tab polls /metrics ~2x/s, so a
# rising hit count means one is up — works on Wayland and X11). We launch it in a window we own
# (Chrome --app, else a separate Firefox instance) so teardown can close just the dashboard.
open_dashboard() {
  local url="http://localhost:$WEB_PORT"
  if [ "${DS4_NO_BROWSER:-0}" = "1" ]; then ok "browser auto-open off (DS4_NO_BROWSER=1) — visit $url"; return; fi
  if [ -z "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]; then warn "no display — open $url in a browser"; return; fi
  local hits='import sys,json; print(json.load(sys.stdin).get("metrics_hits",0))'
  local h0 h1
  h0=$(curl -s "http://127.0.0.1:$SIDE_PORT/healthz" 2>/dev/null | python3 -c "$hits" 2>/dev/null); h0=${h0:-0}
  sleep 1.3
  h1=$(curl -s "http://127.0.0.1:$SIDE_PORT/healthz" 2>/dev/null | python3 -c "$hits" 2>/dev/null); h1=${h1:-0}
  if [ "$h1" -gt "$h0" ]; then ok "dashboard already open (polling detected) — leaving your tab as-is"; return; fi
  # Launch a window we OWN so Ctrl+C can close just the dashboard (registered for teardown).
  local -a cmd=()
  if [ -n "${DS4_BROWSER:-}" ]; then
    cmd=(${DS4_BROWSER} "$url")
  else
    local c b=""
    for c in google-chrome google-chrome-stable chromium chromium-browser brave-browser; do
      command -v "$c" >/dev/null 2>&1 && { b="$c"; break; }
    done
    if [ -n "$b" ]; then
      cmd=("$b" "--app=$url" "--user-data-dir=$RUN_DIR/browser" --no-first-run --no-default-browser-check)
    elif command -v firefox >/dev/null 2>&1; then
      local prof="$RUN_DIR/ffprofile"
      mkdir -p "$prof"                       # GUI Firefox errors if the --profile dir is missing
      cat > "$prof/user.js" <<'PREFS'
user_pref("browser.aboutwelcome.enabled", false);
user_pref("browser.startup.homepage_override.mstone", "ignore");
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
PREFS
      cmd=(firefox --no-remote --profile "$prof" --new-window "$url")
    fi
  fi
  if [ "${#cmd[@]}" -eq 0 ]; then
    ( "${DS4_OPENER:-xdg-open}" "$url" >/dev/null 2>&1 & )
    warn "opened a tab via xdg-open — can't auto-close it on Ctrl+C"
    return
  fi
  "${cmd[@]}" >/dev/null 2>&1 &
  register "dashboard window" "$!"
  ok "opening dashboard in its own window (closes on Ctrl+C) → $url"
}

verify_dir() {  # candidate -> sets DS4_DIR, MODEL
  local d="${1/#\~/$HOME}"
  [ -n "$d" ] && [ -d "$d" ]            || { errln "not a directory: ${1:-<empty>}"; return 1; }
  [ -x "$d/ds4-server" ]                || { errln "no ds4-server binary in $d  (build it — e.g. make cuda-generic, or the rocm/cpu target)"; return 1; }
  [ -e "$d/ds4flash.gguf" ]             || { errln "no ds4flash.gguf in $d  (run ./download_model.sh)"; return 1; }
  DS4_DIR="$(cd "$d" && pwd)"; MODEL="$DS4_DIR/ds4flash.gguf"; return 0
}

# ======================================================================
printf '%s%sds4Service%s  —  DS4 inference + web UI launcher\n\n' "$B" "$CYN" "$RST"

# ---------- 1. ds4 install directory ----------
say "1. ds4 install directory"
SETUP=0; DS4_FLAGS_CLI=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --setup)        SETUP=1 ;;
    --ds4-flags)    shift; DS4_FLAGS_CLI="${1:-}" ;;
    --ds4-flags=*)  DS4_FLAGS_CLI="${1#*=}" ;;
    *)              warn "ignoring unknown argument: $1" ;;
  esac
  shift
done
saved=""; [ -f "$CONFIG_FILE" ] && saved="$(cat "$CONFIG_FILE" 2>/dev/null)"

# Interactive setup. Today this is just the ds4 install dir; future options go here too.
run_setup() {
  local default="${saved:-/home/grant/Dev/ds4}"
  while :; do
    read -r -p "    Path to ds4 install [$default]: " ans || { echo; exit 1; }
    ans="${ans:-$default}"
    if verify_dir "$ans"; then
      ok "verified: $DS4_DIR"
      mkdir -p "$CONFIG_DIR"; printf '%s\n' "$DS4_DIR" > "$CONFIG_FILE"
      ok "saved to $CONFIG_FILE"
      return 0
    fi
    default="$ans"
  done
}

if [ "$SETUP" = "1" ]; then
  ok "setup requested (--setup)"
  run_setup
elif [ -n "$saved" ] && verify_dir "$saved"; then
  ok "using saved ds4 install: $DS4_DIR"
  printf '    %s(re-run with --setup to change)%s\n' "$DIM" "$RST"
else
  [ -n "$saved" ] && warn "saved ds4 dir no longer valid ($saved) — running setup"
  run_setup
fi

# ---------- 2. metrics sidecar ----------
say "2. metrics sidecar"
[ -f "$SIDECAR" ] || { errln "metrics_sidecar.py not found beside ds4Service ($SIDECAR)"; exit 1; }
chmod +x "$SIDECAR" 2>/dev/null || true
ok "ready: $SIDECAR"

# ---------- 3. launch ds4-server ----------
say "3. launching ds4-server (:$SERVER_PORT, ctx $SERVER_CTX)"
preflight_ports "$SERVER_PORT:ds4-server" "$SIDE_PORT:sidecar" "$AGENT_PORT:agent-tools" "$WEB_PORT:frontend" || exit 1
if [ "${DS4_NO_WARM:-0}" != "1" ]; then
  ( cat "$MODEL" >/dev/null 2>&1 ) & register "model-warm (cat)" "$!"
  ok "warming model into RAM page cache (background)"
fi
# --- backend profile: auto-detect, fully overridable (env inherited, --ds4-flags, profile file) ---
PROFILE_FILE="$CONFIG_DIR/profile"
[ -f "$PROFILE_FILE" ] && . "$PROFILE_FILE"     # optional: export HSA_*, set DS4_BACKEND / DS4_SERVER_FLAGS / DS4_SERVER_ENV / DS4_LD_PATH
detect_backend() {
  command -v nvidia-smi >/dev/null 2>&1 && { echo cuda; return; }
  { command -v rocm-smi >/dev/null 2>&1 || command -v rocminfo >/dev/null 2>&1 || [ -d /opt/rocm ]; } && { echo rocm; return; }
  echo cpu
}
FLAGS="${DS4_FLAGS_CLI:-${DS4_SERVER_FLAGS:-}}"   # precedence: --ds4-flags > $DS4_SERVER_FLAGS > per-backend default
DS4_BACKEND="${DS4_BACKEND:-}"
if [ -z "$DS4_BACKEND" ]; then                    # infer from explicit flags, else sniff the hardware
  case " $FLAGS " in
    *" --rocm "*) DS4_BACKEND=rocm ;;
    *" --cuda "*) DS4_BACKEND=cuda ;;
    *" --cpu "*)  DS4_BACKEND=cpu ;;
    *)            DS4_BACKEND="$(detect_backend)" ;;
  esac
fi
case "$DS4_BACKEND" in
  cuda) DEFENV="DS4_CUDA_NO_DIRECT_IO=1 DS4_CUDA_KEEP_MODEL_PAGES=1"; DEFLD="/usr/local/cuda/lib64"; AUTOFLAGS="--cuda --ssd-streaming" ;;
  rocm) DEFENV=""; DEFLD="/opt/rocm/lib"; AUTOFLAGS="--rocm --ssd-streaming" ;;
  cpu)  DEFENV=""; DEFLD=""; AUTOFLAGS="" ;;
  *)    DEFENV=""; DEFLD=""; AUTOFLAGS="--$DS4_BACKEND --ssd-streaming" ;;
esac
[ -z "$FLAGS" ] && FLAGS="$AUTOFLAGS"
DS4_SERVER_ENV="${DS4_SERVER_ENV:-$DEFENV}"
DS4_LD_PATH="${DS4_LD_PATH:-$DEFLD}"
ok "backend: $DS4_BACKEND   ds4-server flags: ${FLAGS:-(none / cpu)}   (override: --ds4-flags / DS4_BACKEND / DS4_SERVER_ENV / DS4_LD_PATH)"
SERVER_LOG="$RUN_DIR/ds4-server.log"
( cd "$DS4_DIR"
  [ -n "$DS4_LD_PATH" ] && export LD_LIBRARY_PATH="$DS4_LD_PATH:${LD_LIBRARY_PATH:-}"
  for kv in $DS4_SERVER_ENV; do export "$kv"; done
  exec ./ds4-server $FLAGS --ctx "$SERVER_CTX" --cors --port "$SERVER_PORT"
) > "$SERVER_LOG" 2>&1 &
register "ds4-server" "$!"
printf '    waiting for model load '
if wait_http "http://127.0.0.1:$SERVER_PORT/v1/models" 180; then
  printf '\n'; ok "ds4-server online"
else
  printf '\n'; errln "ds4-server did not come up — last log lines:"; tail -n 18 "$SERVER_LOG" >&2; cleanup
fi

# ---------- 4. sidecar + frontend ----------
say "4. starting sidecar (:$SIDE_PORT) and ds4Frontend (:$WEB_PORT)"
SIDE_LOG="$RUN_DIR/sidecar.log"
( exec python3 "$SIDECAR" --port "$SIDE_PORT" --model "$MODEL" --backend "$DS4_BACKEND" ) > "$SIDE_LOG" 2>&1 &
register "metrics-sidecar" "$!"
printf '    sidecar '; wait_http "http://127.0.0.1:$SIDE_PORT/healthz" 10 && { printf '\n'; ok "sidecar online (model gauge → $(basename "$MODEL"))"; } || { printf '\n'; warn "sidecar slow/own port busy"; }

AGENT_LOG="$RUN_DIR/agent-tools.log"
( exec python3 "$CODE_DIR/agent_tools.py" --port "$AGENT_PORT" ) > "$AGENT_LOG" 2>&1 &
register "agent-tools" "$!"
printf '    agent-tools '
if wait_http "http://127.0.0.1:$AGENT_PORT/healthz" 10; then echo; ok "agent-tools online (sandboxed file I/O for Agent mode)"; else echo; warn "agent-tools slow/own port busy"; fi

WEB_LOG="$RUN_DIR/frontend.log"
( cd "$CODE_DIR" && exec python3 -m http.server "$WEB_PORT" ) > "$WEB_LOG" 2>&1 &
register "ds4Frontend (web)" "$!"
printf '    frontend '; wait_http "http://127.0.0.1:$WEB_PORT/index.html" 10 && { printf '\n'; ok "frontend online"; } || { printf '\n'; warn "frontend slow/own port busy"; }

# ---------- 4b. open the dashboard ----------
open_dashboard

# ---------- 5. stream logs ----------
say "5. up and running"
printf '    %sOpen:%s  %shttp://localhost:%s%s\n' "$B" "$RST" "$CYN" "$WEB_PORT" "$RST"
printf '    Live logs below (%s[ds4-server.log]%s / %s[sidecar.log]%s / %s[frontend.log]%s).  %sPress Ctrl+C to stop everything.%s\n\n' \
  "$CYN" "$RST" "$DIM" "$RST" "$GRN" "$RST" "$B" "$RST"
tail -n +1 -F "$SERVER_LOG" "$SIDE_LOG" "$AGENT_LOG" "$WEB_LOG" & TAIL_PID=$!
wait "$TAIL_PID"
# tail ended on its own (a server died?) — tear down too.
cleanup
